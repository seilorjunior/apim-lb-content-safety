<!--
  API-level base policy.
  - Sets the round-robin pool as the default backend.
  - Authenticates upstream with APIM's managed identity (Cognitive Services
    audience).
  - Throttles per subscription (rate-limit: short burst window;
    quota: 24h ceiling). Counter keys fall back to the gateway IP for unauthenticated
    requests; in practice every authenticated caller has a subscription, but the
    fallback prevents a NullReferenceException if the API is ever opened anonymously.
  - Retries on 429/5xx three times with exponential-ish backoff.
  - Echoes a correlation id (W3C traceparent or x-ms-client-request-id) on
    every response.

  __POOL_BACKEND_ID__ is replaced at deploy time by apim.bicep with the actual
  pool backend name (currently "cs-pool").
-->
<policies>
  <inbound>
    <base />
    <!--
      Throttle per APIM subscription. The retry-after value (seconds) is echoed
      via a 429 response by APIM. Numbers tuned for a thin proxy in front of
      Content Safety: 60 req/min burst, 10000 req/day ceiling.
    -->
    <rate-limit-by-key calls="60"
                       renewal-period="60"
                       counter-key="@(context.Subscription?.Id ?? context.Request.IpAddress)" />
    <quota-by-key calls="10000"
                  renewal-period="86400"
                  counter-key="@(context.Subscription?.Id ?? context.Request.IpAddress)" />
    <set-backend-service backend-id="__POOL_BACKEND_ID__" />
    <authentication-managed-identity resource="https://cognitiveservices.azure.com" />
    <set-header name="x-correlation-id" exists-action="skip">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
  </inbound>
  <backend>
    <retry condition="@(context.Response.StatusCode == 429 || (context.Response.StatusCode >= 500 &amp;&amp; context.Response.StatusCode &lt; 600))"
           count="3"
           interval="1"
           max-interval="10"
           delta="2"
           first-fast-retry="false">
      <forward-request buffer-request-body="true" />
    </retry>
  </backend>
  <outbound>
    <base />
    <set-header name="x-correlation-id" exists-action="override">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
